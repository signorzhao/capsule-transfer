# 后端
LAN_CAPSULE_HOST=0.0.0.0
LAN_CAPSULE_PORT=5005
# 数据目录（默认 server/data/）
# LAN_CAPSULE_DATA_DIR=/absolute/path/to/data
# 单胶囊包大小上限（MB），默认 1024
# LAN_CAPSULE_MAX_BUNDLE_MB=2048
# CORS 白名单，多个用逗号；默认 *（局域网内宽松）
# LAN_CAPSULE_CORS=http://localhost:3100
# 共享密钥；非空时收发都需要 X-Capsule-Token 请求头
# LAN_CAPSULE_SHARED_TOKEN=please-change-me

# 前端
# VITE_API_BASE=http://127.0.0.1:5005
