{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "CapsuleTransfer",
  "version": "0.7.0",
  "identifier": "com.capsuletransfer.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "npm run dev --prefix ../webapp",
    "frontendDist": "../webapp/dist",
    "devUrl": "http://localhost:3100"
  },
  "app": {
    "windows": [
      {
        "title": "CapsuleTransfer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../data-pipeline/**/*",
      "binaries/*"
    ]
  },
  "plugins": {}
}
