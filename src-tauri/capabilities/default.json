{
  "identifier": "default",
  "description": "Default capabilities for Sound Capsule",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-execute"
  ]
}
